{
  "name": "synapse",
  "version": "0.1.0",
  "description": "A vocabulary learning plugin with spaced repetition and matching games",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build:angular": "cd src/angular && ng build --configuration=production",
    "build:angular:bundle": "cd src/angular/dist/synapse-angular/browser && npx esbuild main.js --bundle --platform=browser --outfile=../../../../../dist/angular-ui.js --format=iife --minify",
    "build:plugin": "node esbuild.config.mjs --production",
    "build": "npm run build:angular && npm run build:angular:bundle && npm run build:plugin && cp manifest.json styles.css dist/"
  },
  "keywords": [
    "obsidian",
    "vocabulary",
    "learning",
    "spaced-repetition",
    "fsrs"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.0.0",
    "typescript": "^5.0.0"
  }
}